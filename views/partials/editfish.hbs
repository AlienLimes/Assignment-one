<form class="ui stacked segment form" method="POST" action="/fishtank/{{fishtankId}}/updatefish/{{id}}">
  <tr class="hide" id="edit{{@index}}">
    <td>
      <span class="ui input">
        <input type="text" name="name" autofocus required
          title="Please include a valid Fish Name"
          placeholder="Fish Name" value="{{name}}">
      </span>
    </td>
    <td>
      <span class="ui input">
        <input type="text" name="species" required
          title="Please include a valid Species"
          placeholder="Species" value="{{species}}">
      </span>
    </td>
    <td>
      <span class="ui input">
        <input type="text" name="color" required
          title="Please include a valid Color"
          placeholder="Color" value="{{color}}">
      </span>
    </td>
    <td>
      <span class="ui input">
        <input type="text" name="gender" required
          title="Please include a valid Gender"
          placeholder="Gender" value="{{gender}}">
      </span>
    </td>
    <td class="center aligned">
    
      <button type = "reset" class = "editSubmit" id="hideEdit{{@index}}" 
        title="Exit without saving">
         <i class="ui undo icon"></i>
</button>

    </td>
    <td class="center aligned">
      <button type="submit" class="editSubmit"
              title="Save changes">
        <i class="ui save icon"></i>
      </button>
    </td>
  </tr>
</form>