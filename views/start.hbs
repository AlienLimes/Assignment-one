{{!-- {{> menu}} --}}
{{> menu id="home"}}

<section class="ui center aligned middle aligned segment">


 <div class="aquarium">

  <h2>Welcome to my Fish Tank App!</h2>
    <p>
      Keeping Fish is a hobby of consistency.
      <br> Fish Tank App helps you maintain  that consistency by tracking the essential tasks.
      <br> Fish type, Fish color, Tank status, ammonia and other parameter levels.
    </p>
    <br>


<img src = "/catFish.png" class = "ui centered image" alt="Catfish illustration" >


<div style="margin-top: 32px;">
  <a href="/about" class="ui large yellow button">
    <i class="info circle icon"></i>
    Learn More About Us

    </a>
</div>

  <div class="ui three statistics" style="margin-top: 4em;">
    
  {{#with info}}
     
    <div class="statistic">
      <div class="value">
        <i class="anchor icon"></i>
      </div>
      <div class="label">
        App Title: <br>
       <strong>{{appTitle}}</strong> 
      </div>
    </div>
    

     
    <div class="statistic">
      <div class="value">
        <i class="map pin icon"></i> 
      </div>
      <div class="label">
        Made in: <br>
        <strong>{{location}}</strong>
      </div>
    </div> 
	
    <div class="statistic">
      <div class="value">
        <i class="smile outline icon"></i>
      </div>
      <div class="label">
        Created by: <br>
        <strong>{{creators.0.name}}</strong>
      </div>
    </div>
	
  
	
  {{/with}}
  
</div>


</div>

 
  <div class="circle bubble-1"></div>
  <div class="circle bubble-2"></div>
  <div class="circle bubble-3"></div>
  <div class="circle bubble-4"></div>
  <div class="circle bubble-5"></div>
  <div class="circle bubble-6"></div>
  <div class="circle bubble-7"></div>
  <div class="circle bubble-8"></div>



</section>
{{> footer}}